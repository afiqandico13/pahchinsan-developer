---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL, SITE } from '../consts';
---
<BaseLayout
  title="Contact"
  description="Hubungi PahchinSan Developer — terbuka untuk freelance (web/app/ML), konsultasi tech, atau sekadar diskusi stack."
>
  <section class="container-wide py-16 md:py-20">
    <p class="section-label">~/contact</p>
    <h1 class="font-display text-4xl text-ink-50 sm:text-5xl md:text-6xl">
      Let's <span class="text-accent-400">build</span> something.
    </h1>
    <p class="mt-4 max-w-2xl text-ink-200">
      Freelance inquiry, konsultasi tech, diskusi stack — semua welcome. Brief kasar pun boleh. Form di bawah, atau langsung WA / email kalau lebih cepat.
    </p>
  </section>

  <section class="container-wide grid gap-10 pb-20 md:grid-cols-5">
    <!-- FORM -->
    <form
      action="https://formspree.io/f/your-form-id"
      method="POST"
      class="md:col-span-3 space-y-4 rounded-box border border-ink-700 bg-ink-800/30 p-6 md:p-8"
      aria-label="Form kontak"
    >
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="form-control">
          <span class="label-text mb-1 font-mono text-xs uppercase tracking-widest text-ink-300">Name</span>
          <input type="text" name="name" required minlength="2"
                 class="input input-bordered w-full bg-ink-900" placeholder="Siapa namamu?" />
        </label>
        <label class="form-control">
          <span class="label-text mb-1 font-mono text-xs uppercase tracking-widest text-ink-300">Email</span>
          <input type="email" name="email" required
                 class="input input-bordered w-full bg-ink-900" placeholder="kamu@email.id" />
        </label>
      </div>

      <label class="form-control">
        <span class="label-text mb-1 font-mono text-xs uppercase tracking-widest text-ink-300">Subject</span>
        <select name="subject" class="select select-bordered w-full bg-ink-900">
          <option>Web portfolio (Tier S/M/L)</option>
          <option>Custom web app / landing page</option>
          <option>Machine learning / data analysis</option>
          <option>Automation / scripting</option>
          <option>Just saying hi</option>
        </select>
      </label>

      <label class="form-control">
        <span class="label-text mb-1 font-mono text-xs uppercase tracking-widest text-ink-300">Budget range</span>
        <select name="budget" class="select select-bordered w-full bg-ink-900">
          <option>Belum ada gambaran</option>
          <option>&lt; Rp 1 juta</option>
          <option>Rp 1 - 3 juta</option>
          <option>Rp 3 - 5 juta</option>
          <option>Rp 5 - 10 juta</option>
          <option>&gt; Rp 10 juta</option>
        </select>
      </label>

      <label class="form-control">
        <span class="label-text mb-1 font-mono text-xs uppercase tracking-widest text-ink-300">Message</span>
        <textarea name="message" required rows="6"
                  class="textarea textarea-bordered w-full bg-ink-900"
                  placeholder="Ceritakan project-nya — apa yang mau dibangun, timeline, dll…"></textarea>
      </label>

      <div class="flex flex-wrap items-center justify-between gap-3 pt-2">
        <p class="font-mono text-xs text-ink-400">
          Replies dalam 24 jam. Form托管 via Formspree — ganti <code class="rounded bg-ink-900 px-1 text-teal-400">your-form-id</code> di code.
        </p>
        <button type="submit" class="btn btn-primary">Send Message →</button>
      </div>
    </form>

    <!-- SIDEBAR -->
    <aside class="md:col-span-2 space-y-6">
      <div class="rounded-box border border-ink-700 bg-ink-800/30 p-6">
        <h2 class="mb-3 font-display text-lg text-ink-50">Direct</h2>
        <ul class="space-y-2 font-mono text-sm">
          <li>
            <a href={`mailto:${SITE.email}`} class="link link-underline break-all text-accent-400 hover:text-accent-300">
              {SITE.email}
            </a>
          </li>
          <li>
            <a href={`https://wa.me/62${SITE.whatsapp.slice(1)}`} class="link link-underline text-accent-400 hover:text-accent-300">
              WhatsApp · {SITE.whatsapp}
            </a>
          </li>
        </ul>
      </div>

      <div class="rounded-box border border-ink-700 bg-ink-800/30 p-6">
        <h2 class="mb-3 font-display text-lg text-ink-50">~/socials</h2>
        <ul class="space-y-2 font-mono text-sm">
          {SOCIAL.map(s => (
            <li>
              <a class="link link-hover text-ink-100 hover:text-accent-400" href={s.url} target="_blank" rel="noopener me">
                <span class="text-ink-200">{s.name}</span>
                <span class="ml-1 text-ink-400">— {s.handle}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-box border border-accent-400/30 bg-gradient-to-br from-accent-400/10 to-ink-900 p-6">
        <h2 class="mb-2 font-display text-lg text-ink-50">Based in</h2>
        <p class="font-mono text-sm text-ink-200">
          Jimbaran, Bali 🇮🇩<br />
          <span class="text-ink-400">UTC+8 · slow internet ok</span>
        </p>
      </div>
    </aside>
  </section>
</BaseLayout>
