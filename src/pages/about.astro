---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../consts';

// Work history — IT-relevant only
const pengalaman = [
  { year: '2026 — sekarang', role: 'IT Support', org: 'Cube Cafe Jimbaran', desc: 'Day job. Remote troubleshooting, automasi backup, network maintenance, helpdesk.' },
  { year: '2025', role: 'Staf Khusus Rektor & Wakil Direktur Operasional', org: 'ITB STIKOM Bali Kampus Abiansemal', desc: 'Skripsi Orange Data Mining — klasifikasi Marketing/SDM/Operasional. Digitalisasi administrasi via Google Workspace.' },
  { year: '2024 — 2025', role: 'Supervisor Computer Club Admin', org: 'PT. Colizeum Arena Bali Ubud', desc: 'Network & computer lab management.' },
  { year: '2024 — sekarang', role: 'Marketing Representative (MGM Program)', org: 'ITB STIKOM Bali', desc: 'Student ambassador program.' },
];

const techSkills = [
  { group: 'Frontend', items: ['Astro', 'Next.js', 'Vue', 'React', 'Tailwind CSS', 'TypeScript', 'daisyUI'] },
  { group: 'Backend',  items: ['Node.js', 'Python (Flask/FastAPI)', 'PHP', 'REST API', 'WebSocket'] },
  { group: 'Data / ML', items: ['Python', 'scikit-learn', 'Orange Data Mining', 'Pandas', 'NumPy'] },
  { group: 'DevOps',   items: ['Git', 'Docker', 'VSCode', 'WSL', 'Vercel', 'Netlify', 'GitHub Actions'] },
  { group: 'Security', items: ['Static code review', 'Network security fundamentals (FCNS)', 'Burp Suite', 'OWASP Top 10'] },
];

const sertifikasi = [
  'DOT Test (Grade 1 & 2)',
  'CIPMP — Project Management',
  'FCNS — Network Security',
  'LSPP — Programmer',
  'DM — Digital Marketing',
];
---
<BaseLayout
  title="About"
  description="Tentang PahchinSan Developer — IT Support, web/app developer, dan ML engineer oleh Afiq Andico (Pahchin)."
>
  <!-- INTRO -->
  <section class="container-wide py-16 md:py-24">
    <div class="grid gap-12 md:grid-cols-12">
      <div class="md:col-span-7">
        <p class="section-label">~/about</p>
        <h1 class="font-display text-4xl leading-tight text-ink-50 sm:text-5xl md:text-6xl">
          Saya <span class="text-accent-400">Pahchin</span>.<br />
          Ini studio saya.
        </h1>
        <div class="prose-dev mt-8">
          <p>
            Saya <strong>{SITE.fullName}</strong> — dipanggil <strong>Pahchin</strong>. Lahir di Situbondo, 9 Juli 2001. Tinggal di Denpasar Utara, Bali sejak usia 1–2 tahun.
          </p>
          <p>
            {SITE.name} adalah studio kecil yang aku bangun di 2024 untuk ngerjain project IT freelance — website, aplikasi, model ML, pipeline data. Engineering rapi, eksekusi terukur, no-bullshit.
          </p>
          <p>
            Motto: <em>"{SITE.motto}"</em> — bukan jargon, itu kompas harian.
          </p>
          <p>
            Day job: <strong>{SITE.role}</strong>. Sambil nunggu yudisium S1 Sistem Informasi ITB STIKOM Bali (5 Juli 2026).
          </p>
        </div>
      </div>

      <aside class="md:col-span-5">
        <div class="sticky top-24 space-y-4">
          <!-- ID CARD -->
          <div class="overflow-hidden rounded-box border border-ink-700 bg-ink-800">
            <div class="border-b border-ink-700 bg-ink-900 px-5 py-3">
              <div class="flex items-center gap-2">
                <span class="h-2.5 w-2.5 rounded-full bg-coral-400"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-teal-400"></span>
                <span class="ml-2 font-mono text-xs text-ink-300">whoami.json</span>
              </div>
            </div>
            <div class="space-y-3 p-5 font-mono text-sm">
              <div class="flex justify-between"><span class="text-ink-300">name</span><span class="text-ink-50">"Pahchin"</span></div>
              <div class="flex justify-between"><span class="text-ink-300">legal_name</span><span class="text-ink-50 text-xs">"Afiq Andico P."</span></div>
              <div class="flex justify-between"><span class="text-ink-300">role</span><span class="text-accent-400">"Full-stack · ML"</span></div>
              <div class="flex justify-between"><span class="text-ink-300">day_job</span><span class="text-ink-50 text-xs">"IT Support @ Cube Cafe"</span></div>
              <div class="flex justify-between"><span class="text-ink-300">base</span><span class="text-ink-50">"Jimbaran, Bali"</span></div>
              <div class="flex justify-between"><span class="text-ink-300">status</span><span class="text-ink-50">"Open for freelance"</span></div>
              <div class="flex justify-between"><span class="text-ink-300">email</span><span class="text-ink-100 text-xs">{SITE.email}</span></div>
              <div class="flex justify-between"><span class="text-ink-300">github</span><span class="text-ink-100 text-xs">@pahchinsan</span></div>
            </div>
          </div>

          <!-- CONTACT CARD -->
          <div class="rounded-box border border-ink-600 bg-ink-800/50 p-5">
            <p class="font-mono text-xs uppercase tracking-widest text-accent-400">~/contact</p>
            <ul class="mt-3 space-y-1.5 font-mono text-sm">
              <li class="flex items-center gap-2 text-ink-200">
                <span class="text-ink-400">email</span> → <a href={`mailto:${SITE.email}`} class="text-accent-400 hover:underline">{SITE.email}</a>
              </li>
              <li class="flex items-center gap-2 text-ink-200">
                <span class="text-ink-400">wa</span> → <a href={`https://wa.me/62${SITE.whatsapp.slice(1)}`} class="text-accent-400 hover:underline">{SITE.whatsapp}</a>
              </li>
              <li class="flex items-center gap-2 text-ink-200">
                <span class="text-ink-400">loc</span> → Jimbaran, Bali 🇮🇩
              </li>
            </ul>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- TECH STACK -->
  <section class="border-y border-ink-700 bg-ink-800/30 py-16 md:py-24">
    <div class="container-wide">
      <p class="section-label">~/stack</p>
      <h2 class="mb-10 font-display text-3xl text-ink-50 sm:text-4xl">Tech yang biasa aku pakai.</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {techSkills.map(group => (
          <div>
            <p class="mb-3 font-mono text-xs uppercase tracking-widest text-accent-400">{group.group}</p>
            <ul class="space-y-1.5">
              {group.items.map(item => (
                <li class="font-mono text-sm text-ink-100">› {item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PENGALAMAN KERJA -->
  <section class="container-wide py-16 md:py-24">
    <p class="section-label">~/experience</p>
    <h2 class="mb-10 font-display text-3xl text-ink-50 sm:text-4xl">Pengalaman (IT).</h2>
    <ol class="relative space-y-8 border-l border-ink-700 pl-8">
      {pengalaman.map(p => (
        <li class="relative">
          <span class="absolute -left-[42px] flex h-8 w-8 items-center justify-center rounded-full border border-accent-400 bg-ink-900 font-mono text-[10px] text-accent-400">
            ●
          </span>
          <p class="font-mono text-xs uppercase tracking-widest text-ink-300">{p.year}</p>
          <h3 class="mt-1 font-display text-lg text-ink-50">{p.role} <span class="text-ink-300">— {p.org}</span></h3>
          <p class="mt-1 text-sm text-ink-200">{p.desc}</p>
        </li>
      ))}
    </ol>
  </section>

  <!-- SERTIFIKASI -->
  <section class="border-t border-ink-700 bg-ink-800/30 py-16 md:py-24">
    <div class="container-wide">
      <p class="section-label">~/certs</p>
      <h2 class="mb-6 font-display text-3xl text-ink-50 sm:text-4xl">Sertifikasi.</h2>
      <div class="flex flex-wrap gap-2">
        {sertifikasi.map(cert => (
          <span class="rounded-full border border-ink-600 bg-ink-900 px-4 py-1.5 font-mono text-sm text-ink-100">
            ✓ {cert}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- RESEARCH -->
  <section class="container-wide py-16 md:py-24">
    <p class="section-label">~/research</p>
    <h2 class="mb-10 font-display text-3xl text-ink-50 sm:text-4xl">Penelitian.</h2>
    <div class="grid gap-6 md:grid-cols-2">
      <div class="rounded-box border border-ink-600 bg-ink-800/30 p-6">
        <p class="font-mono text-xs uppercase tracking-widest text-accent-400">skripsi · 2025</p>
        <h3 class="mt-2 font-display text-xl text-ink-50">Orange Data Mining — Klasifikasi 3 Domain</h3>
        <p class="mt-2 text-sm text-ink-200">
          Optimasi Manajemen Marketing, SDM, &amp; Operasional Kampus Abiansemal — integrasi tiga domain dalam satu model klasifikasi terpadu.
        </p>
        <div class="mt-4 grid grid-cols-3 gap-3">
          <div class="rounded border border-ink-700 bg-ink-900 p-3 text-center">
            <p class="font-mono text-xl text-accent-400">94%</p>
            <p class="font-mono text-[10px] text-ink-300">Marketing<br>(Random Forest)</p>
          </div>
          <div class="rounded border border-ink-700 bg-ink-900 p-3 text-center">
            <p class="font-mono text-xl text-accent-400">77%</p>
            <p class="font-mono text-[10px] text-ink-300">SDM<br>(Decision Tree)</p>
          </div>
          <div class="rounded border border-ink-700 bg-ink-900 p-3 text-center">
            <p class="font-mono text-xl text-accent-400">89%</p>
            <p class="font-mono text-[10px] text-ink-300">Operasional<br>(SVM/k-NN)</p>
          </div>
        </div>
      </div>

      <div class="rounded-box border border-ink-600 bg-ink-800/30 p-6">
        <p class="font-mono text-xs uppercase tracking-widest text-accent-400">kriptografi · 2025</p>
        <h3 class="mt-2 font-display text-xl text-ink-50">Teori Andico-Ruby</h3>
        <p class="mt-2 text-sm text-ink-200">
          Metode enkripsi hibrid orisinal — Dynamic Recursive Shift + Transformasi Energi-Informasi.
        </p>
        <div class="mt-4 grid grid-cols-3 gap-3">
          <div class="rounded border border-ink-700 bg-ink-900 p-3 text-center">
            <p class="font-mono text-xl text-teal-400">9.1</p>
            <p class="font-mono text-[10px] text-ink-300">bit entropy</p>
          </div>
          <div class="rounded border border-ink-700 bg-ink-700 p-3 text-center">
            <p class="font-mono text-xl text-teal-400">0.1%</p>
            <p class="font-mono text-[10px] text-ink-300">collision</p>
          </div>
          <div class="rounded border border-ink-700 bg-ink-900 p-3 text-center">
            <p class="font-mono text-xl text-teal-400">0.14ms</p>
            <p class="font-mono text-[10px] text-ink-300">per data</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PERSONAL BRANDS (CLEAR SEPARATION) -->
  <section class="border-t border-ink-700 bg-ink-800/30 py-16 md:py-24">
    <div class="container-wide">
      <p class="section-label">~/context</p>
      <h2 class="mb-3 font-display text-3xl text-ink-50 sm:text-4xl">Luar studio ini, saya juga:</h2>
      <p class="mb-10 max-w-2xl text-ink-200">
        Untuk konteks lain — riset personal, karya seni, atau hal-hal di luar tech — ada identity terpisah.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="https://github.com/afiqandico13" class="card-hover block rounded-box border border-ink-600 bg-ink-900/50 p-5 transition-colors hover:border-accent-400/60">
          <p class="font-display text-lg text-accent-400">Afiq Andico Pangimpian</p>
          <p class="mt-1 font-mono text-xs text-ink-300">Personal · research · ML · security</p>
          <p class="mt-2 text-sm text-ink-200">Riset LSTM, security reviews, dan project personal di github.com/afiqandico13</p>
        </a>
        <a href="https://github.com/anotherwaltz" class="card-hover block rounded-box border border-ink-600 bg-ink-900/50 p-5 transition-colors hover:border-coral-400/60">
          <p class="font-display text-lg text-coral-400">Another Waltz</p>
          <p class="mt-1 font-mono text-xs text-ink-300">Art collective · musik · lukis · foto</p>
          <p class="mt-2 text-sm text-ink-200">Kolektif seni Bali. Karya lukis, musik, foto — di-handle sebagai Ruby Rubhin.</p>
        </a>
        <div class="rounded-box border border-ink-600 bg-ink-900/50 p-5">
          <p class="font-display text-lg text-teal-400">Inbound inquiries</p>
          <p class="mt-1 font-mono text-xs text-ink-300">Studio · freelance · konsultasi</p>
          <p class="mt-2 text-sm text-ink-200">Untuk project IT — langsung via email atau WhatsApp di bawah.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
