---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SOCIAL, NAV, TECH_STACK } from '../consts';

// Featured projects — mix of code + creative side projects.
const featured = [
  {
    title: 'Taskflow — Demo Web App',
    cat: 'Web App',
    stack: 'React · single-file SPA',
    img: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?auto=format&fit=crop&w=1200&h=900&q=80',
    alt: 'Laptop dengan kode di layar dalam gelap',
    href: '/demos/',
    desc: 'Aplikasi manajemen tugas dengan auth, CRUD, filter, dan search. Built single-file dengan React 18 + Babel.',
    accent: 'accent',
  },
  {
    title: 'Studio Pricing Calculator',
    cat: 'Tool',
    stack: 'Vanilla HTML · Tailwind CDN',
    img: 'https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&w=1200&h=900&q=80',
    alt: 'Calculator dengan notepad di atas meja',
    href: '/studio/',
    desc: 'Interactive pricing calculator untuk jasa web portfolio. Tier S/M/L + add-ons, format Rupiah real-time.',
    accent: 'teal',
  },
  {
    title: 'Astro Portfolio Template',
    cat: 'Open Source',
    stack: 'Astro 4 · Tailwind · daisyUI',
    img: 'https://images.unsplash.com/photo-1542831371-29b0f74f9713?auto=format&fit=crop&w=1200&h=900&q=80',
    alt: 'Kode editor dengan syntax highlighting',
    href: '/work/',
    desc: 'Reusable template untuk klien. Single config file drives everything. Decap CMS built-in.',
    accent: 'coral',
  },
  {
    title: 'Teori Andico-Ruby',
    cat: 'Research',
    stack: 'Python · Kriptografi',
    img: 'https://images.unsplash.com/photo-1635070041078-e363dbe005cb?auto=format&fit=crop&w=1200&h=900&q=80',
    alt: 'Diagram matematika di papan tulis',
    href: '/work/',
    desc: 'Metode enkripsi hibrid orisinal. Entropy 9.1 bit, collision 0.1%, 0.14 ms/data. Desktop + Web (Flask).',
    accent: 'accent',
  },
];
---
<BaseLayout title={SITE.name} description={SITE.description}>
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-ink-700">
    <div class="container-wide grid items-center gap-12 py-20 md:grid-cols-12 md:py-28">
      <div class="md:col-span-7">
        <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-ink-500 bg-ink-800/40 px-3 py-1 font-mono text-xs text-ink-100">
          <span class="inline-block h-1.5 w-1.5 animate-pulse rounded-full bg-teal-400"></span>
          {SITE.brandTag} · Bali, ID
        </p>
        <h1 class="font-display text-4xl font-semibold leading-[1.05] text-ink-50 sm:text-5xl md:text-6xl lg:text-7xl">
          <span class="text-accent-400">Web, App,</span><br />
          ML &amp; Data<br />
          <span class="text-ink-300">— built with intent.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg text-ink-200">
          Studio kecil di Bali milik <strong class="text-ink-50">{SITE.author}</strong> — IT Support by day, membangun website, aplikasi, dan model machine learning by night. Engineering rapi, eksekusi terukur, no-bullshit.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/work/" class="btn btn-primary">Lihat Karya</a>
          <a href="/demos/" class="btn btn-outline btn-secondary">Coba Demo</a>
          <a href="/contact/" class="btn btn-ghost">Diskusi project →</a>
        </div>
        <p class="mt-6 font-mono text-xs uppercase tracking-widest text-ink-300">
          <span class="text-accent-400">$</span> open for freelance · IT Support day job
        </p>
      </div>

      <div class="relative md:col-span-5">
        <div class="overflow-hidden rounded-box border border-ink-600 bg-ink-800 shadow-2xl">
          <!-- Terminal-style card -->
          <div class="flex items-center gap-2 border-b border-ink-600 bg-ink-700 px-4 py-2">
            <span class="h-2.5 w-2.5 rounded-full bg-coral-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-yellow-400"></span>
            <span class="h-2.5 w-2.5 rounded-full bg-teal-400"></span>
            <span class="ml-2 font-mono text-xs text-ink-300">~/pahchinsan — bash</span>
          </div>
          <pre class="overflow-x-auto p-5 font-mono text-xs leading-relaxed text-ink-100"><code><span class="text-teal-400">pahchin@studio</span>:<span class="text-accent-400">~</span>$ whoami
<span class="text-ink-50">Afiq Andico (Pahchin)</span>
<span class="text-ink-50">— IT Support @ Cube Cafe Jimbaran</span>
<span class="text-ink-50">— Founder, PahchinSan Developer</span>

<span class="text-teal-400">pahchin@studio</span>:<span class="text-accent-400">~</span>$ cat stack.txt
<span class="text-ink-50">Astro · Next.js · Python · Flask</span>
<span class="text-ink-50">Tailwind · daisyUI · TypeScript</span>
<span class="text-ink-50">scikit-learn · Orange · FastAPI</span>

<span class="text-teal-400">pahchin@studio</span>:<span class="text-accent-400">~</span>$ ./contact.sh
<span class="text-accent-400">→ afiqandico13@gmail.com</span>
<span class="text-accent-400">→ +62 899 0308 936</span>
<span class="text-coral-400">→ ready</span></code></pre>
        </div>
        <div class="absolute -bottom-6 -right-6 -z-10 hidden h-32 w-32 rounded-full bg-accent-400/20 blur-3xl md:block"></div>
      </div>
    </div>
  </section>

  <!-- TECH STACK -->
  <section class="border-b border-ink-700 bg-ink-800/30 py-12">
    <div class="container-wide">
      <p class="mb-6 font-mono text-xs uppercase tracking-widest text-ink-300">
        <span class="text-accent-400">#</span> stack yang biasa aku pakai
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {TECH_STACK.map(group => (
          <div>
            <p class="mb-3 font-mono text-xs uppercase tracking-widest text-accent-400">{group.group}</p>
            <ul class="space-y-1.5">
              {group.items.map(item => (
                <li class="font-mono text-sm text-ink-100">› {item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED WORK -->
  <section class="container-wide py-16 md:py-24">
    <div class="mb-10 flex items-end justify-between gap-4">
      <div>
        <p class="mb-2 font-mono text-xs uppercase tracking-widest text-accent-400">~/featured</p>
        <h2 class="font-display text-3xl text-ink-50 sm:text-4xl">Karya Pilihan</h2>
      </div>
      <a href="/work/" class="btn btn-sm btn-ghost">Semua karya →</a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {featured.map(f => (
        <a href={f.href}
           class="card-hover group relative overflow-hidden rounded-box border border-ink-600 bg-ink-800/40 transition-all hover:border-accent-400/60">
          <div class="aspect-[4/5] overflow-hidden">
            <img
              src={f.img}
              alt={f.alt}
              loading="lazy"
              decoding="async"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
          </div>
          <div class="space-y-1.5 p-4">
            <p class="font-mono text-[10px] uppercase tracking-widest text-accent-400">{f.cat}</p>
            <h3 class="font-display text-lg leading-tight text-ink-50">{f.title}</h3>
            <p class="font-mono text-xs text-ink-300">{f.stack}</p>
            <p class="pt-1 text-sm text-ink-200">{f.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- MOTTO -->
  <section class="bg-ink-800/30 py-12">
    <div class="container-wide">
      <p class="text-center font-display text-2xl italic leading-relaxed text-ink-100 md:text-3xl">
        "{SITE.motto}"
      </p>
      <p class="mt-3 text-center font-mono text-xs uppercase tracking-widest text-ink-300">— {SITE.author}, founder</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="container-wide py-16">
    <div class="rounded-box border border-ink-600 bg-gradient-to-br from-ink-800/80 to-ink-900 p-8 md:p-14">
      <div class="grid items-center gap-8 md:grid-cols-2">
        <div>
          <p class="mb-2 font-mono text-xs uppercase tracking-widest text-accent-400">~/next</p>
          <h2 class="font-display text-3xl text-ink-50 sm:text-4xl">Mau bangun sesuatu?</h2>
          <p class="mt-3 max-w-md text-ink-200">
            Terbuka untuk freelance — website, app, model ML, automation pipeline. Atau sekadar diskusi stack. WA atau email aja.
          </p>
        </div>
        <div class="flex flex-wrap gap-3 md:justify-end">
          <a href="/contact/" class="btn btn-primary">Hubungi</a>
          <a href="/studio/" class="btn btn-outline">Lihat Pricing</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
