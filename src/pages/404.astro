---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 — Not Found" description="Halaman yang kamu cari tidak ada.">
  <section class="container-wide grid min-h-[60vh] place-items-center py-20 text-center">
    <div class="max-w-md">
      <p class="font-display text-7xl text-accent-400">404</p>
      <h1 class="mt-2 font-display text-2xl text-ink-50">Halaman tidak ditemukan</h1>
      <p class="mt-3 font-mono text-sm text-ink-300">
        <span class="text-coral-400">error</span>: route tidak exist. Mungkin halaman ini pindah atau URL salah ketik.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-2">
        <a href="/" class="btn btn-primary">~/home</a>
        <a href="/work/" class="btn btn-outline">~/work</a>
        <a href="/blog/" class="btn btn-ghost">~/blog</a>
      </div>
    </div>
  </section>
</BaseLayout>
