---
import { NAV, SITE } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href);
---
<header class="sticky top-0 z-50 border-b border-ink-700 bg-ink-900/80 backdrop-blur supports-[backdrop-filter]:bg-ink-900/60">
  <div class="container-wide flex h-16 items-center justify-between">
    <a href="/" class="group flex items-center gap-2 font-display text-lg font-semibold tracking-tight text-ink-50">
      <span class="inline-block h-2.5 w-2.5 rounded-full bg-accent-400 transition-transform duration-500 group-hover:scale-150"></span>
      <span>{SITE.brandShort}<span class="text-accent-400">.</span>dev</span>
    </a>

    <nav aria-label="Utama" class="hidden md:block">
      <ul class="menu menu-horizontal gap-1 px-1 font-mono text-sm">
        {NAV.map(item => (
          <li>
            <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}
               class:list={[
                 'rounded-btn px-3 py-2 transition-colors text-ink-200',
                 isActive(item.href) ? '!text-accent-400' : 'hover:!text-accent-400',
               ]}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="md:hidden">
      <div class="dropdown dropdown-end">
        <button tabindex="0" class="btn btn-ghost btn-sm text-ink-100" aria-label="Buka menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <ul tabindex="0" class="menu dropdown-content z-50 mt-3 w-56 rounded-box border border-ink-600 bg-ink-800 p-2 font-mono text-sm shadow-xl">
          {NAV.map(item => (
            <li><a href={item.href} class="text-ink-100 hover:text-accent-400" aria-current={isActive(item.href) ? 'page' : undefined}>{item.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</header>
